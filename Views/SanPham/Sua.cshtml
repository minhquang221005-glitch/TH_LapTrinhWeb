@model Buoi1.Models.SanPham
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Chỉnh sửa sản phẩm";
}

<div class="container">
        <div class="card shadow-sm" style="max-width: 600px; margin: auto;">
            <div class="card-header bg-primary text-white">
                <h5 class="m-0 fw-bold">CHỈNH SỬA SẢN PHẨM (ID: @Model.Id)</h5>
            </div>
            <div class="card-body">
                <form asp-action="Sua" method="post">

                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="TenSanPham" class="form-label fw-bold">Tên Sản Phẩm:</label>
                        <input asp-for="TenSanPham" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Gia" class="form-label fw-bold">Giá bán (VNĐ):</label>
                        <input asp-for="Gia" class="form-control" type="number" required />
                    </div>

                    <div class="mb-4">
                        <label asp-for="HinhAnh" class="form-label fw-bold">Link Hình Ảnh (Copy link dán vào đây):</label>
                        <input asp-for="HinhAnh" class="form-control" placeholder="https://..." />

                        @* View trước cái ảnh đang có *@
                        @if (!string.IsNullOrEmpty(Model.HinhAnh))
                        {
                            <div class="mt-2 p-2 border rounded bg-white text-center">
                                <span class="d-block text-muted small mb-1">Ảnh hiện tại:</span>
                                <img src="@Model.HinhAnh" style="max-height: 120px; object-fit: contain;" />
                            </div>
                        }
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary fw-bold">LƯU THAY ĐỔI</button>
                        <a href="/SanPham/Index" class="btn btn-outline-secondary">Trở về danh sách</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
