@model IEnumerable<Buoi1.Models.SanPham>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Kho Hàng";
}

<div class="container" style="padding-top:20px;">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold text-danger m-0">KHO HÀNG CỦA THỊNH PC</h2>
            <a href="/SanPham/Them" class="btn btn-success fw-bold shadow-sm">
                + THÊM SẢN PHẨM MỚI
            </a>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <table class="table table-hover table-bordered m-0 text-center align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th width="10%">Mã SP</th>
                            <th width="10%">Hình Ảnh</th>
                            <th width="40%">Tên Sản Phẩm</th>
                            <th width="20%">Giá Bán</th>
                            <th width="20%">Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-bold">@item.Id</td>

                                    <td>
                                        <div class="bg-white border rounded p-1 d-inline-block">
                                            @if (!string.IsNullOrEmpty(item.HinhAnh))
                                            {
                                                <img src="@item.HinhAnh" alt="@item.TenSanPham" style="width: 50px; height: 50px; object-fit: contain;">
                                            }
                                            else
                                            {
                                                <img src="https://loremflickr.com/50/50/computer,parts?lock=@item.Id" alt="Fake" style="width: 50px; height: 50px; object-fit: contain;">
                                            }
                                        </div>
                                    </td>
                                    <td class="text-start">@item.TenSanPham</td>
                                    <td class="text-danger fw-bold">@item.Gia.ToString("N0") đ</td>
                                    <td>
                                        <a href="/SanPham/Sua/@item.Id" class="btn btn-sm btn-primary">Sửa</a>
                                        <a href="/SanPham/Xoa/@item.Id" class="btn btn-sm btn-danger" onclick="return confirm('Mày có chắc chắn muốn xóa con hàng này không?');">Xóa</a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-muted py-4">
                                    <i>Kho đang trống trơn. Bấm nút Thêm Sản Phẩm đi mậy!</i>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
