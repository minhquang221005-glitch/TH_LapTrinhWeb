@model List<Buoi1.Models.CartItem>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Giỏ hàng";
    var totalPrice = Model?.Sum(x => x.ThanhTien) ?? 0;
}

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-light">
                <h5 class="m-0">
                    <i class="fa-solid fa-cart-shopping me-2" style="color: var(--primary-color);"></i>
                    Giỏ hàng của bạn
                </h5>
            </div>

            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 100px;">Ảnh</th>
                                <th>Sản phẩm</th>
                                <th style="width: 120px;">Giá</th>
                                <th style="width: 150px;">Số lượng</th>
                                <th style="width: 150px;">Thành tiền</th>
                                <th style="width: 80px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <div style="width: 80px; height: 80px; background: #f5f5f5; display: flex; align-items: center; justify-content: center; border-radius: 6px; overflow: hidden;">
                                            @if (!string.IsNullOrEmpty(item.HinhAnh))
                                            {
                                                <img src="@item.HinhAnh" alt="@item.TenSanPham" 
                                                     style="max-height: 100%; max-width: 100%; object-fit: contain;"
                                                     onerror="this.src='https://via.placeholder.com/80x80?text=Product'">
                                            }
                                            else
                                            {
                                                <i class="fa-solid fa-image fa-2x text-muted opacity-25"></i>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        <strong>@item.TenSanPham</strong>
                                    </td>
                                    <td>
                                        <span style="color: var(--primary-color); font-weight: 600;">
                                            @item.Gia.ToString("N0")đ
                                        </span>
                                    </td>
                                    <td>
                                        <form asp-action="CapNhatSoLuong" method="post" class="d-flex gap-2 align-items-center">
                                            <input type="hidden" name="id" value="@item.SanPhamId">
                                            <input type="number" name="soLuong" value="@item.SoLuong" 
                                                   min="1" max="100" class="form-control" 
                                                   style="width: 70px; padding: 6px 8px; font-size: 0.9rem;">
                                            <button type="submit" class="btn btn-sm btn-outline-primary">
                                                <i class="fa-solid fa-check"></i>
                                            </button>
                                        </form>
                                    </td>
                                    <td>
                                        <strong style="color: var(--primary-color); font-size: 1.05rem;">
                                            @item.ThanhTien.ToString("N0")đ
                                        </strong>
                                    </td>
                                    <td>
                                        <a href="/Cart/Xoa/@item.SanPhamId" class="btn btn-sm btn-outline-danger"
                                           onclick="return confirm('Xóa sản phẩm này?')">
                                            <i class="fa-solid fa-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="card-footer bg-light d-flex justify-content-between align-items-center">
                    <a href="/Cart/XoaToan" class="btn btn-outline-danger" onclick="return confirm('Xóa toàn bộ giỏ hàng?')">
                        <i class="fa-solid fa-trash-alt me-1"></i> Xóa toàn bộ
                    </a>
                    <a href="/Home/Index" class="btn btn-outline-secondary">
                        <i class="fa-solid fa-arrow-left me-1"></i> Tiếp tục mua hàng
                    </a>
                </div>
            }
            else
            {
                <div class="card-body text-center py-5">
                    <i class="fa-solid fa-cart-shopping fa-4x text-muted opacity-25 mb-3"></i>
                    <h5 class="text-muted">Giỏ hàng trống</h5>
                    <p class="text-muted small mb-3">Bạn chưa thêm sản phẩm nào vào giỏ hàng</p>
                    <a href="/Home/Index" class="btn btn-primary">
                        <i class="fa-solid fa-shopping-bag me-1"></i> Tiếp tục mua hàng
                    </a>
                </div>
            }
        </div>
    </div>

    <!-- Sidebar Checkout -->
    <div class="col-lg-4">
        <div class="card shadow-sm border-0 position-sticky" style="top: 100px;">
            <div class="card-header bg-light">
                <h6 class="m-0 fw-bold">Tóm tắt đơn hàng</h6>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-6">
                        <span class="text-muted">Số sản phẩm:</span>
                    </div>
                    <div class="col-6 text-end">
                        <strong>@(Model?.Count ?? 0)</strong>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-6">
                        <span class="text-muted">Tạm tính:</span>
                    </div>
                    <div class="col-6 text-end">
                        <strong>@totalPrice.ToString("N0")đ</strong>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-6">
                        <span class="text-muted">Phí vận chuyển:</span>
                    </div>
                    <div class="col-6 text-end">
                        <strong>Miễn phí</strong>
                    </div>
                </div>

                <hr>

                <div class="row mb-4">
                    <div class="col-6">
                        <span class="fw-bold">Tổng cộng:</span>
                    </div>
                    <div class="col-6 text-end">
                        <strong style="color: var(--primary-color); font-size: 1.3rem;">
                            @totalPrice.ToString("N0")đ
                        </strong>
                    </div>
                </div>

                @if (Model != null && Model.Any())
                {
                    <div class="d-grid gap-2">
                        <form asp-action="ThanhToan" method="post">
                            <button type="submit" class="btn btn-primary w-100 fw-bold py-2">
                                <i class="fa-solid fa-credit-card me-2"></i>
                                THANH TOÁN NGAY
                            </button>
                        </form>
                    </div>
                    
                    <div class="alert alert-info small mt-3 mb-0">
                        <i class="fa-solid fa-info-circle me-2"></i>
                        Bạn sẽ được chuyển đến trang thanh toán để hoàn tất đơn hàng.
                    </div>
                }
                else
                {
                    <button class="btn btn-primary w-100 fw-bold py-2" disabled>
                        THANH TOÁN NGAY
                    </button>
                    <div class="alert alert-warning small mt-3 mb-0">
                        <i class="fa-solid fa-warning me-2"></i>
                        Giỏ hàng trống. Vui lòng thêm sản phẩm trước khi thanh toán.
                    </div>
                }
            </div>

            <!-- Trust Badges -->
            <div class="card-footer bg-light">
                <div class="row text-center g-2">
                    <div class="col-4">
                        <div class="small">
                            <i class="fa-solid fa-shield text-success fa-lg mb-2"></i>
                            <div style="font-size: 0.75rem; color: var(--text-muted);">Bảo mật</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="small">
                            <i class="fa-solid fa-truck text-primary fa-lg mb-2"></i>
                            <div style="font-size: 0.75rem; color: var(--text-muted);">Miễn phí ship</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="small">
                            <i class="fa-solid fa-undo text-info fa-lg mb-2"></i>
                            <div style="font-size: 0.75rem; color: var(--text-muted);">Trả trong 7 ngày</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Prevent negative quantity
        document.querySelectorAll('input[type="number"]').forEach(input => {
            input.addEventListener('change', function() {
                if (this.value < 1) this.value = 1;
                if (this.value > 100) this.value = 100;
            });
        });
    </script>
}
