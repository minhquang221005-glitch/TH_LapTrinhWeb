@model IEnumerable<Buoi1.Models.SanPham>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Trang chủ";
}

<div>
    <div class="mb-4">
        <h2 class="fw-bold mb-2">
            <i class="fa-solid fa-star text-warning"></i>
            <span class="ms-2">SẢN PHẨM MỚI & HOT</span>
        </h2>
        <hr class="border-danger opacity-25">
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4 g-4">
            @foreach (var item in Model)
            {
                var giaGoc = item.Gia * 1.1;
                <div class="col">
                    <div class="card h-100 product-card">
                        <span class="sale-tag">
                            <i class="fa-solid fa-tag me-1"></i>-10%
                        </span>

                        <div class="product-image-wrapper position-relative">
                            @if (!string.IsNullOrEmpty(item.HinhAnh))
                            {
                                <img src="@(item.HinhAnh?.Trim())"
                                     alt="@item.TenSanPham"
                                     onerror="this.style.display='none'; this.parentElement.querySelector('.img-placeholder').classList.remove('d-none');"
                                     loading="lazy"
                                     referrerpolicy="no-referrer"
                                     crossorigin="anonymous" />
                                <div class="img-placeholder d-none w-100 h-100 d-flex align-items-center justify-content-center bg-light">
                                    <i class="fa-solid fa-image fa-3x text-muted opacity-50"></i>
                                </div>
                            }
                            else
                            {
                                <div class="img-placeholder w-100 h-100 d-flex align-items-center justify-content-center bg-light">
                                    <i class="fa-solid fa-image fa-3x text-muted opacity-50"></i>
                                </div>
                            }
                        </div>

                        <div class="card-body p-3 d-flex flex-column">
                            <h6 class="card-title fw-bold mb-2" 
                                style="font-size: 0.95rem; 
                                       display: -webkit-box; 
                                       -webkit-line-clamp: 2; 
                                       -webkit-box-orient: vertical; 
                                       overflow: hidden;
                                       min-height: 2.8em;">
                                @item.TenSanPham
                            </h6>

                            <div class="mb-2 mt-auto">
                                <div class="price-old text-decoration-line-through small mb-1">
                                    @giaGoc.ToString("N0")đ
                                </div>
                                <div class="price-new">
                                    @item.Gia.ToString("N0")đ
                                </div>
                            </div>

                            <div class="product-actions">
                                <a href="/Home/ChiTiet/@item.Id" class="btn btn-sm btn-outline-secondary flex-grow-1">
                                    <i class="fa-solid fa-eye me-1"></i>Xem chi tiết
                                </a>
                                <form action="/Cart/ThemVaoGio" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Thêm vào giỏ">
                                        <i class="fa-solid fa-cart-plus"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            <i class="fa-solid fa-circle-info me-2"></i>
            <strong>Kho hàng đang trống!</strong> Bấm nút "Quản lý" để thêm sản phẩm vào kho.
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
</div>

@section Scripts {
    <script>
        // Xử lý lỗi hình ảnh với retry
        document.querySelectorAll('img[onerror]').forEach(img => {
            img.addEventListener('error', function() {
                if (!this.hasAttribute('data-retry')) {
                    this.setAttribute('data-retry', 'true');
                    setTimeout(() => {
                        this.src = this.src;
                    }, 1000);
                } else {
                    this.src = 'https://via.placeholder.com/200x200?text=Lỗi+ảnh';
                }
            });
        });

        // Lazy loading polyfill cho trình duyệt cũ
        if (!('loading' in HTMLImageElement.prototype)) {
            document.querySelectorAll('img[loading="lazy"]').forEach(img => {
                img.removeAttribute('loading');
            });
        }
    </script>
}
