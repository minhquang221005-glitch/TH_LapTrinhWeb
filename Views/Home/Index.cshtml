@model IEnumerable<Buoi1.Models.XeMay>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Trang chu";
}

<style>
    .xe-card {
        border: 1px solid #e0e0e0;
        border-radius: 12px;
        overflow: hidden;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        background: #fff;
        cursor: pointer;
        height: 100%;
    }

        .xe-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 24px rgba(0,0,0,0.12);
        }

        .xe-card .card-img-wrap {
            width: 100%;
            padding-top: 65%;
            position: relative;
            overflow: hidden;
            background: #f5f5f5;
        }

            .xe-card .card-img-wrap img {
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                object-fit: cover;
                transition: transform 0.3s ease;
            }

        .xe-card:hover .card-img-wrap img {
            transform: scale(1.04);
        }

        .xe-card .card-img-wrap .img-placeholder {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f8f9fa;
        }

    .tag-moi {
        position: absolute;
        top: 10px;
        left: 10px;
        background: #e63946;
        color: white;
        font-size: 0.7rem;
        font-weight: 600;
        padding: 2px 8px;
        border-radius: 4px;
        z-index: 1;
    }

    .gia-moi {
        color: #e63946;
        font-size: 1.15rem;
        font-weight: 700;
    }

    .gia-cu {
        color: #aaa;
        font-size: 0.82rem;
        text-decoration: line-through;
    }

    .ten-xe {
        font-size: 0.95rem;
        font-weight: 600;
        color: #1a1a1a;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        min-height: 2.8em;
    }

    .badge-thongso {
        background: #f0f4ff;
        color: #3a3a6e;
        border-radius: 6px;
        font-size: 0.72rem;
        font-weight: 500;
        padding: 3px 7px;
        display: inline-block;
    }

    .hang-xe {
        font-size: 0.78rem;
        color: #999;
    }
</style>

<div class="container-fluid px-3 mt-4">
    <div class="mb-4">
        <h2 class="fw-bold mb-2">
            <i class="fa-solid fa-star text-warning"></i>
            <span class="ms-2">SAN PHAM MOI & HOT</span>
        </h2>
        <hr class="border-danger opacity-25">
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-3">
            @foreach (var item in Model)
            {
                var giaGoc = item.Gia * 1.1m;
                <div class="col">
                    <div class="xe-card">
                        <div class="card-img-wrap position-relative">
                            <span class="tag-moi">-10%</span>
                            @if (!string.IsNullOrEmpty(item.HinhAnh))
                            {
                                <img src="@item.HinhAnh" alt="@item.TenSanPham" loading="lazy"
                                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                                <div class="img-placeholder" style="display:none;">
                                    <i class="fa-solid fa-image fa-3x text-muted opacity-50"></i>
                                </div>
                            }
                            else
                            {
                                <div class="img-placeholder">
                                    <i class="fa-solid fa-image fa-3x text-muted opacity-50"></i>
                                </div>
                            }
                        </div>

                        <div class="p-3 d-flex flex-column gap-2">
                            <p class="ten-xe mb-0">@item.TenSanPham</p>

                            <div>
                                <div class="gia-cu">@giaGoc.ToString("N0")d</div>
                                <div class="gia-moi">@item.Gia.ToString("N0")d</div>
                            </div>

                            <div class="d-flex flex-wrap gap-1">
                                <span class="badge-thongso">@item.NamSanXuat</span>
                                <span class="badge-thongso">@item.PhanKhoi cc</span>
                                <span class="badge-thongso">@item.MauSac</span>
                            </div>

                            <div class="hang-xe border-top pt-2">
                                @(item.HangXe?.TenHang ?? "N/A")
                            </div>

                            <div class="d-flex gap-2 mt-1">
                                <a href="/Home/ChiTiet/@item.Id" class="btn btn-sm btn-outline-secondary flex-grow-1">
                                    <i class="fa-solid fa-eye me-1"></i>Xem chi tiet
                                </a>
                                <form action="/Cart/ThemVaoGio" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm btn-danger">
                                        <i class="fa-solid fa-cart-plus"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="fa-solid fa-circle-info me-2"></i>
            <strong>Kho hang dang trong!</strong>
        </div>
    }
</div>


---

