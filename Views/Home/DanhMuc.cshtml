@model IEnumerable<Buoi1.Models.SanPham>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = ViewBag.TenDanhMuc ?? "Danh mục";
    var title = ViewBag.TenDanhMuc as string ?? "Sản phẩm";
}

<div>
    <div class="mb-4">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-3">
                <li class="breadcrumb-item"><a href="/Home/Index" class="text-decoration-none">Trang chủ</a></li>
                <li class="breadcrumb-item active">@title</li>
            </ol>
        </nav>

        <h2 class="fw-bold">
            <i class="fa-solid fa-filter"></i>
            <span class="ms-2">@title</span>
            <span class="badge bg-gearvn ms-2">@(Model?.Count() ?? 0)</span>
        </h2>
        <hr class="border-danger opacity-25 mt-3">
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4 g-4">
            @foreach (var item in Model)
            {
                var giaGoc = item.Gia * 1.1m;
                <div class="col">
                    <div class="card h-100 product-card">
                        <span class="sale-tag">
                            <i class="fa-solid fa-tag me-1"></i>-10%
                        </span>

                        <div class="product-img-wrapper position-relative">
                            @if (!string.IsNullOrEmpty(item.HinhAnh))
                            {
                                <img src="@(item.HinhAnh?.Trim())"
                                     alt="@item.TenSanPham"
                                     onerror="this.onerror=null;this.src='https://via.placeholder.com/200x200?text=No+Image'"
                                     loading="lazy"
                                     referrerpolicy="no-referrer"
                                     crossorigin="anonymous" />
                            }
                            else
                            {
                                <div class="w-100 h-100 d-flex align-items-center justify-content-center bg-light">
                                    <i class="fa-solid fa-image fa-3x text-muted opacity-50"></i>
                                </div>
                            }
                        </div>

                        <div class="card-body p-3 d-flex flex-column">
                            <h6 class="card-title fw-bold mb-2"
                                style="font-size: 0.95rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; min-height: 2.8em;">
                                @item.TenSanPham
                            </h6>

                            <div class="mb-2 mt-auto">
                                <div class="price-old text-decoration-line-through small mb-1">
                                    @giaGoc.ToString("N0")đ
                                </div>
                                <div class="price-new">
                                    @item.Gia.ToString("N0")đ
                                </div>
                            </div>

                            <div class="product-actions">
                                <a href="/Home/ChiTiet/@item.Id" class="btn btn-sm btn-outline-secondary flex-grow-1">
                                    <i class="fa-solid fa-eye me-1"></i>Xem chi tiết
                                </a>
                                <form asp-controller="Cart" asp-action="ThemVaoGio" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@item.Id">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Thêm vào giỏ">
                                        <i class="fa-solid fa-cart-plus"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-warning">Không tìm thấy sản phẩm.</div>
    }
</div>
