                <div class="header-actions">
                    @{
                        var userJson = Context.Session.GetString("User");
                        var isLoggedIn = !string.IsNullOrEmpty(userJson);
                        string userName = "";
                        string userRole = "";
                        
                        if (isLoggedIn)
                        {
                            try
                            {
                                var userData = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, object>>(userJson);
                                userName = userData?["TenDangNhap"]?.ToString() ?? "";
                                userRole = userData?["VaiTro"]?.ToString() ?? "";
                            }
                            catch { }
                        }
                    }

                    @if (isLoggedIn)
                    {
                        if (userRole == "Admin")
                        {
                            <a href="/SanPham" class="btn btn-sm btn-warning fw-bold" title="Quản lý sản phẩm">
                                <i class="fa-solid fa-toolbox me-1"></i>
                                <span class="d-none d-lg-inline">Quản lý</span>
                            </a>
                            <a href="/Admin/Dashboard" class="btn btn-sm btn-outline-secondary ms-2">
                                <i class="fa-solid fa-chart-line me-1"></i>
                                <span class="d-none d-lg-inline">Admin Dashboard</span>
                            </a>
                        }

                        <div class="user-section">
                            <i class="fa-solid fa-user-circle fa-lg" style="color: var(--primary-color);"></i>
                            <span class="fw-600 d-none d-sm-inline">@userName</span>
                        </div>
                        <a href="/TaiKhoan/LichSuDonHang" class="btn btn-sm btn-outline-primary ms-2">
                            <i class="fa-solid fa-history me-1"></i>
                            <span class="d-none d-md-inline">Lịch sử</span>
                        </a>

                        <a href="/TaiKhoan/DangXuat" class="btn btn-sm btn-outline-danger">
                            <i class="fa-solid fa-sign-out-alt"></i>
                        </a>
                    }
                    else
                    {
                        <a href="/TaiKhoan/DangNhap" class="btn btn-sm btn-outline-primary">
                            <i class="fa-solid fa-sign-in-alt me-1"></i>
                            <span class="d-none d-md-inline">Đăng nhập</span>
                        </a>
                        <a href="/TaiKhoan/DangKy" class="btn btn-sm btn-outline-danger">
                            <i class="fa-solid fa-user-plus me-1"></i>
                            <span class="d-none d-md-inline">Đăng ký</span>
                        </a>
                    }

                    <a href="/Cart" class="position-relative" title="Giỏ hàng" style="font-size: 1.3rem; color: var(--text-dark); text-decoration: none;">
                        <i class="fa-solid fa-cart-shopping"></i>
                        @{
                            var cartJson = Context.Session.GetString("Cart");
                            var cartCount = 0;
                            if (!string.IsNullOrEmpty(cartJson))
                            {
                                try
                                {
                                    var cart = System.Text.Json.JsonSerializer.Deserialize<List<Dictionary<string, object>>>(cartJson);
                                    cartCount = cart?.Count ?? 0;
                                }
                                catch { }
                            }
                        }
                        @if (cartCount > 0)
                        {
                            <span class="cart-badge">@cartCount</span>
                        }
                    </a>
                </div>
            </div>
        </div>
    </nav>

