    <!-- Mega Menu JS -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const megaMenuTrigger = document.getElementById('megaMenuTrigger');
            const megaMenuContainer = document.getElementById('megaMenuContainer');
            const megaCategoryItems = document.querySelectorAll('.mega-category-item');
            const megaMenuWrapper = document.querySelector('.mega-menu-wrapper');
            const megaMenuRight = document.querySelector('.mega-menu-right');

            if (!megaMenuTrigger || !megaMenuContainer) return;

            // Toggle Mega Menu
            megaMenuTrigger.addEventListener('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                const isActive = megaMenuContainer.classList.contains('active');

                if (isActive) {
                    closeMegaMenu();
                } else {
                    openMegaMenu();
                }
            });

            // Prevent clicks inside menu from bubbling to document
            megaMenuContainer.addEventListener('click', function(e) {
                e.stopPropagation();
            });

            // Open menu
            function openMegaMenu() {
                megaMenuContainer.classList.add('active');
            }

            // Close menu
            function closeMegaMenu() {
                megaMenuContainer.classList.remove('active');
            }

            // Handle category interactions
            megaCategoryItems.forEach((item) => {
                const categoryKey = item.dataset.category;
                const link = item.querySelector('.mega-category-link');

                if (!link) return;

                // Mouseenter for desktop
                item.addEventListener('mouseenter', function() {
                    if (window.innerWidth > 992) {
                        handleCategorySelect(item, categoryKey, megaCategoryItems);
                    }
                });

                // Click for mobile
                link.addEventListener('click', function(e) {
                    if (window.innerWidth <= 992) {
                        e.preventDefault();
                        e.stopPropagation();
                        handleCategorySelect(item, categoryKey, megaCategoryItems);
                    }
                });
            });

            // Handle category selection
            function handleCategorySelect(item, categoryKey, items) {
                items.forEach(cat => cat.classList.remove('active'));
                item.classList.add('active');
                showSubmenu(categoryKey);
            }

            // Show submenu by category
            function showSubmenu(categoryKey) {
                const submenus = document.querySelectorAll('.mega-submenu');
                submenus.forEach(submenu => {
                    submenu.classList.remove('active');
                });

                const activeSubmenu = megaMenuRight.querySelector(`.mega-submenu[data-category="${categoryKey}"]`);
                if (activeSubmenu) {
                    activeSubmenu.classList.add('active');
                }
            }

            // Close menu when clicking outside (click-outside logic)
            document.addEventListener('click', function(e) {
                if (!megaMenuWrapper.contains(e.target)) {
                    closeMegaMenu();
                }
            });

            // Close menu on escape key
            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape') {
                    closeMegaMenu();
                }
            });

            // Set first category as active on load
            if (megaCategoryItems.length > 0) {
                const firstCategory = megaCategoryItems[0].dataset.category;
                megaCategoryItems[0].classList.add('active');
                showSubmenu(firstCategory);
            }

            // Handle window resize
            window.addEventListener('resize', function() {
                if (window.innerWidth > 992 && megaMenuContainer.classList.contains('active')) {
                    closeMegaMenu();
                }
            });
        });
    </script>

    @RenderSection("Scripts", required: false)
