@* Shared layout for MVC Views (e-commerce style) *@
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Thịnh PC - Gaming Gear Store</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/megamenu.css" />
    @RenderSection("Styles", required: false)
    <style>
        :root { 
            --primary-color: #E30019;
            --primary-dark: #c40016;
            --light-bg: #f8f9fa;
            --card-bg: #ffffff;
            --text-dark: #1a1a1a;
            --text-muted: #666666;
            --border-color: #e0e0e0;
        }
        
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body { 
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: var(--light-bg);
            color: var(--text-dark);
            line-height: 1.6;
        }

        /* ========== HEADER ========== */
        .header-top {
            background: #f5f5f5;
            border-bottom: 1px solid var(--border-color);
            padding: 8px 0;
            font-size: 0.85rem;
        }

        .header-top-item {
            display: flex;
            align-items: center;
            gap: 5px;
            color: var(--text-muted);
        }

        .header-top-item a {
            color: var(--text-muted);
            text-decoration: none;
            transition: color 0.2s;
        }

        .header-top-item a:hover {
            color: var(--primary-color);
        }

        .navbar-custom {
            background: white;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            padding: 12px 0;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .navbar-custom .navbar-brand {
            font-size: 1.8rem;
            font-weight: 800;
            color: var(--primary-color) !important;
            margin-right: 30px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .navbar-custom .navbar-brand i {
            font-size: 2rem;
        }

        .search-box {
            flex: 1;
            max-width: 400px;
            margin: 0 20px;
        }

        .search-box input {
            border: 1px solid var(--border-color);
            border-radius: 6px;
            padding: 10px 15px;
            font-size: 0.95rem;
            transition: all 0.2s;
        }

        .search-box input:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 3px rgba(227, 0, 25, 0.1);
        }

        .header-actions {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .header-actions a, .header-actions button {
            color: var(--text-dark);
            text-decoration: none;
            transition: all 0.2s;
            padding: 5px 10px;
            border-radius: 6px;
        }

        .header-actions a:hover, .header-actions button:hover {
            background: var(--light-bg);
            color: var(--primary-color);
        }

        .cart-badge {
            position: absolute;
            top: -8px;
            right: -8px;
            background: var(--primary-color);
            color: white;
            border-radius: 50%;
            width: 24px;
            height: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.75rem;
            font-weight: bold;
        }

        .user-section {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 5px 10px;
            background: var(--light-bg);
            border-radius: 6px;
        }

        /* ========== PRODUCT CARD ========== */
        .product-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 10px;
            overflow: hidden;
            transition: all 0.3s ease;
            display: flex;
            flex-direction: column;
            height: 100%;
            box-shadow: 0 1px 4px rgba(0,0,0,0.06);
        }

        .product-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 10px 30px rgba(227, 0, 25, 0.15);
            border-color: var(--primary-color);
        }

        .product-image-wrapper {
            height: 200px;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f5f5f5;
        }

        .product-image-wrapper img {
            max-height: 190px;
            max-width: 100%;
            object-fit: contain;
            padding: 12px;
            transition: transform 0.3s ease;
        }

        .img-placeholder {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f5f5f5;
        }

        .product-card:hover .product-image-wrapper img {
            transform: scale(1.08);
        }

        .product-badges {
            position: absolute;
            top: 10px;
            right: 10px;
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .badge-discount {
            background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
            color: white;
            padding: 8px 12px;
            border-radius: 6px;
            font-weight: bold;
            font-size: 0.85rem;
            box-shadow: 0 2px 8px rgba(227, 0, 25, 0.3);
        }

        .badge-new {
            background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
            color: white;
            padding: 6px 10px;
            border-radius: 6px;
            font-weight: 600;
            font-size: 0.75rem;
        }

        .product-body {
            padding: 16px;
            display: flex;
            flex-direction: column;
            flex-grow: 1;
        }

        .product-name {
            font-size: 0.95rem;
            font-weight: 600;
            color: var(--text-dark);
            margin-bottom: 8px;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            min-height: 2.8em;
            line-height: 1.4;
        }

        .product-rating {
            display: flex;
            align-items: center;
            gap: 6px;
            margin-bottom: 10px;
            font-size: 0.85rem;
        }

        .product-rating .stars {
            color: #ffc107;
        }

        .product-rating .count {
            color: var(--text-muted);
            font-size: 0.8rem;
        }

        .product-price-section {
            margin: 12px 0;
            padding: 12px 0;
            border-top: 1px solid var(--border-color);
            border-bottom: 1px solid var(--border-color);
        }

        .price-old {
            color: var(--text-muted);
            text-decoration: line-through;
            font-size: 0.9rem;
            margin-bottom: 4px;
        }

        .price-new {
            color: var(--primary-color);
            font-weight: 700;
            font-size: 1.3rem;
        }

        .discount-percent {
            color: var(--primary-color);
            font-weight: 600;
            font-size: 0.9rem;
            margin-left: 8px;
        }

        .product-status {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 0.85rem;
            margin-top: 10px;
            color: #28a745;
        }

        .product-actions {
            display: flex;
            gap: 8px;
            margin-top: auto;
        }

        .btn-outline-danger {
            border-color: var(--primary-color);
            color: var(--primary-color);
        }

        .btn-outline-danger:hover {
            background: var(--primary-color);
            border-color: var(--primary-color);
            color: white;
        }

        /* ========== FOOTER ========== */
        .footer {
            background: var(--text-dark);
            color: #ccc;
            padding: 40px 0 20px;
            margin-top: 60px;
            border-top: 3px solid var(--primary-color);
        }

        .footer a {
            color: #ccc;
            text-decoration: none;
            transition: color 0.2s;
        }

        .footer a:hover {
            color: var(--primary-color);
        }

        .footer-title {
            color: white;
            font-weight: 600;
            margin-bottom: 16px;
            font-size: 1rem;
        }

        .footer-links {
            list-style: none;
            padding: 0;
        }

        .footer-links li {
            margin-bottom: 10px;
            font-size: 0.9rem;
        }

        .alert {
            border-radius: 8px;
            border: none;
            margin-bottom: 20px;
        }

        .alert-success {
            background: #d4edda;
            color: #155724;
        }

        .alert-danger {
            background: #f8d7da;
            color: #721c24;
        }
    </style>
</head>
